sticMeet.jsx", "source_location": "L766"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useState", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L767"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useState", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L768"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useRef", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L769"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useState", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L770"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useRef", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L771"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useState", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L772"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "map", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L774"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useEffect", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L777"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "(() => {\n    const aspect = gridSize.w / Math.max(gridSize.h, 1);\n    let bestCols = 1, bestScore = Infinity;\n    for (let c = 1; c <= count; c++) {\n      const r = Math.ceil(count / c);\n      // How well does this fill? Penalize empty cells + bad tile aspect ratio\n      const empty = c * r - count;\n      const tileW = gridSize.w / c;\n      const tileH = gridSize.h / r;\n      const tileAspect = tileW / Math.max(tileH, 1);\n      // Ideal tile aspect ~16:9 (1.78)\n      const aspectDiff = Math.abs(tileAspect - 1.6);\n      const score = empty * 2 + aspectDiff * 3;\n      if (score < bestScore) { bestScore = score; bestCols = c; }\n    }\n    return { cols: bestCols, rows: Math.ceil(count / bestCols) };\n  })", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L789"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useCallback", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L807"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useCallback", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L814"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useCallback", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L820"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "useCallback", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L838"}, {"caller_nid": "futuristicmeet_futuristicmeet", "callee": "map", "source_file": "/home/sasi/Desktop/dev/RM Orbit/Meet/src/views/FuturisticMeet.jsx", "source_location": "L884"}]}