ee": "(() => {\n                const hasWork     = eventTypes.some(e => (e.category || 'work') === 'work');\n                const hasPersonal = eventTypes.some(e => (e.category || 'work') === 'personal');\n                const showFilter  = hasWork && hasPersonal;\n                const [catTab, setCatTab] = React.useState('all');\n                const filtered = catTab === 'all' ? eventTypes : eventTypes.filter(e => (e.category || 'work') === catTab);\n                return (\n                <>\n                {showFilter && (\n                  <div style={{ display: 'flex', gap: 6, marginBottom: 14 }}>\n                    {[{id:'all',label:'All'},{id:'work',label:'\ud83d\udcbc Work'},{id:'personal',label:'\ud83c\udfe0 Personal'}].map(f => (\n                      <button key={f.id} onClick={() => setCatTab(f.id)} style={{\n                        padding: '6px 14px', borderRadius: 999, border: 'none', cursor: 'pointer',\n                        fontSize: '0.75rem', fontWeight: 700, transition: 'all 0.15s',\n                        background: catTab === f.id ? (f.id === 'personal' ? '#7C3AED' : '#0B3932') : '#F0F0EF',\n                        color: catTab === f.id ? (f.id === 'personal' ? '#fff' : '#F3DF00') : '#6B7280',\n                      }}>{f.label}</button>\n                    ))}\n                  </div>\n                )}\n                <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>\n                  {filtered.map((et, i) => (\n                    <EventCard key={et.id} et={et} index={i} username={username} onClick={() => navigate(`/${username}/${et.slug}`)} />\n                  ))}\n                  <div style={{ display: 'flex', alignItems: 'center', gap: 10, margin: '6px 0' }}>\n                    <div style={{ flex: 1, height: 1, background: '#E5E7EB' }} />\n                    <div style={{ display: 'flex', alignItems: 'center', gap: 5, borderRadius: '999px', padding: '5px 12px', border: '1px solid #E5E7EB', background: '#fff' }}>\n                      <svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#9CA3AF\" strokeWidth=\"2\" strokeLinecap=\"round\"><polygon points=\"23 7 16 12 23 17 23 7\"/><rect x=\"1\" y=\"5\" width=\"15\" height=\"14\" rx=\"2\"/></svg>\n                      <span style={{ fontSize: '0.7rem', color: '#9CA3AF', fontWeight: 600 }}>Video calls via RM Meet</span>\n                    </div>\n                    <div style={{ flex: 1, height: 1, background: '#E5E7EB' }} />\n                  </div>\n                </div>\n                </>\n                );\n              })", "source_file": "/home/sasi/Desktop/dev/RM Orbit/RMBook/src/pages/ProfilePage.jsx", "source_location": "L301"}]}