# LLM configuration
# Default local setup:
RESEARCH_LLM_PROVIDER=ollama
RESEARCH_LLM_MODEL=gemma4:e4b
RESEARCH_LLM_BASE_URL=http://localhost:11434/v1
RESEARCH_LLM_API_KEY=ollama

# External OpenAI-compatible API example:
# RESEARCH_LLM_PROVIDER=openai
# RESEARCH_LLM_MODEL=gpt-4.1
# RESEARCH_LLM_BASE_URL=
# RESEARCH_LLM_API_KEY=sk-...

RESEARCH_LLM_TIMEOUT_SECONDS=180
RESEARCH_LLM_MAX_RETRIES=2
RESEARCH_LLM_JSON_REPAIR_ATTEMPTS=3
