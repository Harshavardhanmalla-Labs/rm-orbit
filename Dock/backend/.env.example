# RM Orbit Dock Server Environment

PORT=6120

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres_secret@localhost:5432/orbit_dock

# Authentication
DOCK_AUTH_MODE=gate
DOCK_GATE_USERINFO_URL=http://auth.freedomlabs.in:45001/api/v1/oidc/userinfo

# Dock -> Secure post-commit assignment sync bridge
POST_COMMIT_SYNC_ENABLED=true
DOCK_SECURE_BRIDGE_URL=http://localhost:6004/api/v1/internal/bridge/dock/assignments
DOCK_SECURE_INTERNAL_TOKEN=
DOCK_SECURE_TIMEOUT_SECONDS=3.0

# Storage
# Connect-compatible S3 configuration for hosting binaries/releases
DOCK_S3_ENDPOINT_URL=https://s3.freedomlabs.in
DOCK_S3_ACCESS_KEY_ID=minioadmin
DOCK_S3_SECRET_ACCESS_KEY=minioadmin
DOCK_S3_BUCKET_NAME=orbit-dock
DOCK_S3_REGION=us-east-1
