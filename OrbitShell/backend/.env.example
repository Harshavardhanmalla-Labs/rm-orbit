# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Service URLs (defaults match local development ports) ──
ATLAS_URL=http://localhost:8000
CALENDAR_URL=http://localhost:5001
CONNECT_URL=http://localhost:5000
MAIL_URL=http://localhost:8004
MEET_URL=http://localhost:6001
WRITER_URL=http://localhost:6011
PLANET_URL=http://localhost:46000
CAPITAL_HUB_URL=http://localhost:6003
SECURE_URL=http://localhost:6004
TURBOTICK_URL=http://localhost:6100
WALLET_URL=http://localhost:6110
DOCK_URL=http://localhost:6120
SEARCH_URL=http://localhost:6200
GATE_URL=http://localhost:45001
CONTROL_CENTER_URL=http://localhost:8077

# ── Shell ports ────────────────────────────────────────────
ORBIT_SHELL_PORT=6300
SHELL_FRONTEND_PORT=45021

# ── Model routing ──────────────────────────────────────────
# Haiku for simple queries, Sonnet for standard, Opus for complex
MODEL_SIMPLE=claude-haiku-4-5
MODEL_STANDARD=claude-sonnet-4-6
MODEL_COMPLEX=claude-opus-4-6
