# RM Orbit Wallet Server Environment

PORT=6110

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres_secret@localhost:5432/orbit_wallet

# Authentication
WALLET_AUTH_MODE=gate
WALLET_GATE_JWKS_URL=http://auth.freedomlabs.in:45001/api/v1/oidc/jwks
# Optional strict validation controls
WALLET_GATE_ISSUER=
WALLET_GATE_AUDIENCE=
WALLET_GATE_JWT_ALGORITHM=RS256

# Cryptography Settings
# Must be exactly 32 url-safe base64-encoded bytes (from Fernet.generate_key())
MASTER_ENCRYPTION_KEY=your-fernet-key-here-change-in-prod
